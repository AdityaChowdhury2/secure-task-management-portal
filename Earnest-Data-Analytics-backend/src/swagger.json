{
  "openapi": "3.0.0",
  "info": {
    "title": "Ahlan Printing Works API",
    "version": "1.0.0",
    "description": "API documentation for Ahlan Printing Works backend"
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "CreateEmployeeDTO": {
        "type": "object",
        "required": ["email", "password", "name", "role"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "john.doe@example.com"
          },
          "password": {
            "type": "string",
            "example": "P@ssw0rd!"
          },
          "phone": {
            "type": "string",
            "nullable": true,
            "example": "+1234567890"
          },
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "role": {
            "type": "string",
            "enum": ["ADMIN", "EMPLOYEE"]
          }
        }
      },
      "TResponse": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer",
            "example": 200
          },
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Operation completed successfully"
          },
          "data": {
            "type": "object"
          }
        }
      },
      "EmployeeData": {
        "type": "object",
        "required": ["id", "email", "name", "employeeId", "phone"],
        "properties": {
          "id": {
            "type": "string",
            "example": "cjld2cjxh0000qzrmn831i7rn"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "jane.doe@example.com"
          },
          "name": {
            "type": "string",
            "example": "Jane Doe"
          },
          "employeeId": {
            "type": "string",
            "example": "EMP-0001"
          },
          "phone": {
            "type": "string",
            "example": "+1234567890"
          }
        }
      },
      "CreateEmployeeResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/TResponse"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/EmployeeData"
              }
            }
          }
        ]
      },
      "AllEmployeesResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/TResponse"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/EmployeeData"
                }
              }
            }
          }
        ]
      },
      "EmployeeDetailsResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/TResponse"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/EmployeeData"
              }
            }
          }
        ]
      },
      "TErrorSource": {
        "type": "object",
        "required": ["path", "message"],
        "properties": {
          "path": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ],
            "example": "email",
            "description": "The field (or array index) that caused the error"
          },
          "message": {
            "type": "string",
            "example": "Email is required",
            "description": "A human‐readable error message for this field"
          }
        }
      },
      "TGenericErrorResponse": {
        "type": "object",
        "required": ["statusCode", "message", "errorSources"],
        "properties": {
          "statusCode": {
            "type": "integer",
            "example": 400,
            "format": "int32",
            "description": "HTTP status code of the error"
          },
          "message": {
            "type": "string",
            "example": "Validation Error",
            "description": "A general error message"
          },
          "errorSources": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TErrorSource"
            },
            "description": "Field‐specific error details"
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/v1/auth/login": {
      "post": {
        "summary": "Login user",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "admin@ahlan.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "admin123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful"
          }
        }
      }
    },
    "/api/v1/auth/refresh-token": {
      "post": {
        "summary": "Refresh access token using refresh token",
        "tags": ["Auth"],
        "responses": {
          "200": {
            "description": "Token refreshed successfully"
          },
          "401": {
            "description": "Invalid or expired refresh token"
          }
        }
      }
    },
    "/api/v1/auth/logout": {
      "delete": {
        "summary": "Logout user and revoke token",
        "tags": ["Auth"],
        "responses": {
          "200": {
            "description": "User logged out"
          }
        }
      }
    },
    "/api/v1/employee/create": {
      "post": {
        "summary": "Create a new employee",
        "tags": ["Employees"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEmployeeDTO"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Employee created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateEmployeeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TGenericErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized (missing or invalid JWT)"
          },
          "403": {
            "description": "Forbidden (insufficient role)"
          }
        }
      }
    },
    "/api/v1/employee": {
      "get": {
        "summary": "Get all employees",
        "tags": ["Employees"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "A list of employees",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AllEmployeesResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized (missing or invalid JWT)"
          },
          "403": {
            "description": "Forbidden (insufficient role)"
          }
        }
      }
    },
    "/api/v1/employee/{id}": {
      "get": {
        "summary": "Get employee details",
        "tags": ["Employees"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Employee details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmployeeDetailsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized (missing or invalid JWT)"
          },
          "403": {
            "description": "Forbidden (insufficient role)"
          }
        }
      }
    },
    "/api/v1/health": {
      "get": {
        "summary": "Health check endpoint",
        "tags": ["Health"],
        "responses": {
          "200": {
            "description": "Returns OK if server and DB are healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "database": {
                      "type": "string",
                      "example": "connected"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Health check failed"
          }
        }
      }
    }
  },
  "tags": []
}
